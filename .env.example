# Telegram bot token from @BotFather
BOT_TOKEN=

# Telegram numeric user id of the admin (the only one who can /genkey, /settoken, etc.)
ADMIN_TG_ID=

# 32-byte key used to encrypt mosreg credentials at rest.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Path to the SQLite database file. Created automatically.
DB_PATH=./data/autoedu.sqlite

# Optional: Default timezone used when interpreting "today"/"tomorrow".
# Mosreg is Moscow-based; leave as Europe/Moscow unless you have a reason to change it.
TZ=Europe/Moscow

# Optional: Route Telegram Bot API traffic through a proxy.
# Useful when the host's outbound to api.telegram.org is blocked but a SOCKS5/HTTP
# proxy is reachable (e.g. running the bot on a Russian home server).
# Mosreg requests always go DIRECTLY through the host's real IP, regardless of this setting.
# Supported schemes: http, https, socks5, socks5h, socks4
# TELEGRAM_PROXY_URL=socks5://192.168.20.3:20170
